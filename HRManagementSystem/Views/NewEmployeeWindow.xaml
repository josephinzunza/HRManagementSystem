<Window x:Class="HRManagementSystem.Views.NewEmployeeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:HRManagementSystem.Views"
        xmlns:uc="clr-namespace:HRManagementSystem.Controls"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
        xmlns:conv="clr-namespace:HRManagementSystem.Controls.Converters"
        mc:Ignorable="d"
        Title="Add a New Employee" Height="800" Width="600"
        ResizeMode="NoResize"
        SizeToContent="Height">
    <Window.Resources>
        <conv:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />
    </Window.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="10" />
            <ColumnDefinition />
            <ColumnDefinition Width="10" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto" />
            <RowDefinition />
            <RowDefinition Height="10" />
        </Grid.RowDefinitions>
        <TextBlock Grid.Column="1" Grid.Row="1" FontSize="36" Margin="0,5">New Employee</TextBlock>
        <Grid Grid.Column="1" Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition />
                <ColumnDefinition />
                <ColumnDefinition />
                <ColumnDefinition />
                <ColumnDefinition />
                <ColumnDefinition />
                <ColumnDefinition />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="10" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <TextBlock Grid.Column="0" Grid.ColumnSpan="8" Grid.Row="0" FontSize="18" Margin="0,10">
                Personal Information
            </TextBlock>
            
            <Label Grid.Column="0" Grid.ColumnSpan="4" Grid.Row="1" Content="First Name:" />
            <uc:ValidationTextBox Grid.Column="0" Grid.ColumnSpan="4" Grid.Row="2" BorderThickness="1" Margin="5" MaxLength="128"
                     Text="{Binding FirstName, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="Enter first name" />

            <Label Grid.Column="4" Grid.ColumnSpan="4" Grid.Row="1" Content="Last Name:"/>
            <uc:ValidationTextBox Grid.Column="4" Grid.ColumnSpan="4" Grid.Row="2" BorderThickness="1" Margin="5" MaxLength="128"
                     Text="{Binding LastName, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="Enter last name"/>

            <Label Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="3" Content="Date of Birth:" />
            <uc:ValidationDateTextBox Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="4" Margin="5"
                        Text="{Binding DateOfBirth}"/>

            <Label Grid.Column="2" Grid.ColumnSpan="3" Grid.Row="3" Content="Gender:" />

            <uc:ValidationComboBox  x:Name="genderComboBox" Margin="5" Grid.Column="2" Grid.ColumnSpan="3" Grid.Row="4"
                    ItemsSource="{Binding Genders}" SelectedItem="{Binding Gender}" >
                <i:Interaction.Triggers>
                    <i:PropertyChangedTrigger Binding="{Binding SelectedItem, ElementName=genderComboBox}">
                        <i:InvokeCommandAction Command="{Binding GenderSelectionChangedCommand}"
                                               CommandParameter="{Binding ElementName=genderComboBox, Path=SelectedIndex}" />
                    </i:PropertyChangedTrigger>
                </i:Interaction.Triggers>
            </uc:ValidationComboBox>


            <Label Grid.Column="5" Grid.ColumnSpan="3" Grid.Row="3" Content="Gender (specify):" />
            <uc:ValidationTextBox Grid.Column="5" Grid.ColumnSpan="3" Grid.Row="4" Margin="5" MaxLength="30"
                     Text="{Binding GenderOther, Mode=TwoWay}" IsEnabled="{Binding IsGenderOtherEnabled}"
                                   PlaceholderText="Specify gender"/>

            <TextBlock Grid.Column="0" Grid.ColumnSpan="8" Grid.Row="5"
                       FontWeight="Bold" FontSize="18" Margin="0,10">
                Contact Information
            </TextBlock>

            <Label Grid.Column="0" Grid.ColumnSpan="3" Grid.Row="6" Content="Phone Number:"/>
            <uc:ValidationPhoneNumberTextBox Grid.Column="0" Grid.ColumnSpan="3" Grid.Row="7" Margin="5" 
                                  PhoneNumber="{Binding PhoneNumber, Mode=TwoWay}" />

            <Label Grid.Column="3" Grid.ColumnSpan="5" Grid.Row="6" Content="Email:"/>
            <uc:ValidationTextBox Grid.Column="3" Grid.ColumnSpan="5" Grid.Row="7" Margin="5" MaxLength="128"
                     Text="{Binding Email}" PlaceholderText="someone@example.com"/>

            <TextBlock Grid.Column="0" Grid.ColumnSpan="8" Grid.Row="8"
                       FontWeight="Bold" FontSize="18" Margin="0,10">
                Address
            </TextBlock>

            <Label Grid.Column="0" Grid.ColumnSpan="5" Grid.Row="9" Content="Street Address:"/>
            <uc:ValidationTextBox Grid.Column="0" Grid.ColumnSpan="5" Grid.Row="10" BorderThickness="1" Margin="5" MaxLength="50"
                     Text="{Binding Address}" PlaceholderText="Enter street address"/>

            <Label Grid.Column="5" Grid.ColumnSpan="3" Grid.Row="9" Content="City:"/>
            <uc:ValidationTextBox Grid.Column="5" Grid.ColumnSpan="3" Grid.Row="10" Margin="5" MaxLength="50"
                     Text="{Binding City}" PlaceholderText="Enter city"/>

            <Label Grid.Column="0" Grid.ColumnSpan="3" Grid.Row="11" Content="Sate:"/>
            <uc:ValidationComboBox Grid.Column="0" Grid.ColumnSpan="3" Grid.Row="12" Margin="5"
                       ItemsSource="{Binding States}" DisplayMemberPath="Name" SelectedItem="{Binding SelectedState}"/>

            <Label Grid.Column="5" Grid.ColumnSpan="3" Grid.Row="11" Content="Zip Code:"/>
            <uc:ValidationTextBox  Grid.Column="5" Grid.ColumnSpan="3" Grid.Row="12"  Margin="5" MaxLength="5"
                     Text="{Binding ZipCode}" PlaceholderText="Enter zip code"/>

            <Button Grid.Column="6" Grid.ColumnSpan="2" Grid.Row="14" Margin="5">
                Save
                <i:Interaction.Triggers>
                    <i:EventTrigger EventName="Click">
                        <i:InvokeCommandAction Command="{Binding AddNewEmployeeCommand}" />
                    </i:EventTrigger>
                </i:Interaction.Triggers>
            </Button>

        </Grid>
    </Grid>
</Window>
