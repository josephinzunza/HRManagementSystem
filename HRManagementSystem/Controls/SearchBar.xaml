<UserControl x:Class="HRManagementSystem.Controls.SearchBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:HRManagementSystem.Controls"
             xmlns:conv="clr-namespace:HRManagementSystem.Controls.Converters"
             mc:Ignorable="d" 
             x:Name="searchBar"
             d:DesignHeight="80" d:DesignWidth="800">
    <Grid>
        <Image Source="{StaticResource searchIconSvg}" HorizontalAlignment="Right" Margin="5,0" Panel.ZIndex="1"
               Stretch="None"/>
        <local:PlaceholderTextBox PlaceholderText="{Binding ElementName=searchBar, Path=PlaceholderText}" />
    </Grid>

</UserControl>
