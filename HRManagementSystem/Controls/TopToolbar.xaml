<UserControl x:Class="HRManagementSystem.Controls.TopToolbar"
             x:Name="topToolbar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:HRManagementSystem.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition MinWidth="75" MaxWidth="100" Width="1*" />
            <ColumnDefinition Width="5*" MaxWidth="800" />
            <ColumnDefinition Width="2*" />
            <ColumnDefinition MinWidth="75" MaxWidth="100" Width="1*" />
        </Grid.ColumnDefinitions>
        <Image Grid.Column="0" Source="{StaticResource ResourceKey=companyLogo}" />
        
        <DockPanel Grid.Column="3">
            <Menu DockPanel.Dock="Top" Margin="10, 0, 10, 10" Background="Transparent" HorizontalAlignment="Right">
                <MenuItem Header="Profile">
                    <MenuItem Header="Log Off"></MenuItem>
                </MenuItem>
            </Menu>
        </DockPanel>

    </Grid>
</UserControl>
