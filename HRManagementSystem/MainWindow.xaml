<Window x:Class="HRManagementSystem.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:HRManagementSystem"
        xmlns:uc="clr-namespace:HRManagementSystem.Controls"
        mc:Ignorable="d"
        Title="HRIS" Height="450" Width="800">        
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition MinWidth="75" MaxWidth="100" Width="1*"/>
            <ColumnDefinition Width="9*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="60" />
            <RowDefinition />
        </Grid.RowDefinitions>
        <uc:TopToolbar Grid.Column="0" Grid.ColumnSpan="2" />
        <ListBox Grid.Column="0" Grid.Row="1" BorderBrush="Transparent" SelectionMode="Single"
                 ScrollViewer.VerticalScrollBarVisibility="Hidden"
                 SelectionChanged="ListBox_SelectionChanged">
            <uc:NavButton IconGeometry="{StaticResource homeIcon}" Padding="10" ToolTip="Home" />
            <uc:NavButton IconGeometry="{StaticResource peopleIcon}" Padding="10" ToolTip="People" NavLink="/Views/EmployeesView.xaml" />
            <uc:NavButton IconGeometry="{StaticResource clockIcon}" Padding="15,10" ToolTip="Time off" />
            <uc:NavButton IconGeometry="{StaticResource cashSignIcon}" Padding="5,10" ToolTip="Payroll" />
            <uc:NavButton IconGeometry="{StaticResource heartIcon}" Padding="5,10" ToolTip="Benefits" />
            <uc:NavButton IconGeometry="{StaticResource reportsIcon}" Padding="10" ToolTip="Reports" />
            <uc:NavButton IconGeometry="{StaticResource editIcon}" Padding="10" ToolTip="Edit benefits, job titles, departments, etc."/>
        </ListBox>
        <Frame x:Name="navFrame" Grid.Column="1" Grid.Row="1" Background="#E9ECEF" Padding="50" />
        
    </Grid>
</Window>
